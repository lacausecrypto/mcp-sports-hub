Output docs/demo.gif
Set FontSize 15
Set Width 1000
Set Height 550
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set Padding 20
Set Shell bash

# Title banner
Type "echo ''"
Enter
Sleep 300ms
Type "echo '  ⚡ mcp-sports-hub — 29 providers, 319 tools, 70+ sports'"
Enter
Sleep 300ms
Type "echo ''"
Enter
Sleep 1s

# NBA scores
Type "echo '  You > What were the NBA scores last night?'"
Enter
Sleep 1.5s
Type "echo ''"
Enter
Sleep 200ms
Type "echo '  Claude > Checking live scores via ESPN...'"
Enter
Sleep 800ms
Type "echo '    LAL 118 - BOS 124  Final'"
Enter
Sleep 300ms
Type "echo '    MIA 105 - PHI 112  Final'"
Enter
Sleep 300ms
Type "echo '    DEN 131 - MIN 128  OT'"
Enter
Sleep 300ms
Type "echo '    GSW 109 - DAL 115  Final'"
Enter
Sleep 2s

